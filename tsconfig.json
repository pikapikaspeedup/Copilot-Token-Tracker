{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "./out",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
